# === MockAPI ===
# Базовый URL и имя ресурса (например /porfolio):
MOCKAPI_BASE_URL=https://66dfd7322fb67ac16f2740dd.mockapi.io
MOCKAPI_RESOURCE=porfolio

# === API ===
PORT=3001
JWT_SECRET=замените-на-длинную-случайную-строку-минимум-32-символа

# === Админ (/admin) — для Express API (опционально) ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=замените-на-надёжный-пароль

# === Frontend ===
VITE_MOCKAPI_URL=https://66dfd7322fb67ac16f2740dd.mockapi.io/porfolio
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=замените-на-надёжный-пароль
VITE_API_URL=
