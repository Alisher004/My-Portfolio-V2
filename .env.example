# === MongoDB ===
# Локально:
# MONGODB_URI=mongodb://127.0.0.1:27017/portfolio
#
# Atlas (замените USER, PASS и cluster):
# MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# === API ===
PORT=3001
JWT_SECRET=замените-на-длинную-случайную-строку-минимум-32-символа

# === Первый администратор (npm run seed:admin) ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=замените-на-надёжный-пароль

# === Frontend ===
# В разработке оставьте пустым — Vite проксирует /api на localhost:3001
VITE_API_URL=
